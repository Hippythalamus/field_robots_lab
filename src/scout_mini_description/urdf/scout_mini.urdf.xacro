<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="scout_mini">

  <!-- ============================================================== -->
  <!-- Properties: Scout Mini physical parameters                     -->
  <!-- Source: AgileX official specifications                          -->
  <!-- ============================================================== -->
  <xacro:property name="base_length" value="0.612"/>
  <xacro:property name="base_width"  value="0.580"/>
  <xacro:property name="base_height" value="0.245"/>
  <xacro:property name="base_mass"   value="22.0"/>

  <xacro:property name="wheel_radius"    value="0.090"/>
  <xacro:property name="wheel_width"     value="0.060"/>
  <xacro:property name="wheel_mass"      value="1.5"/>
  <xacro:property name="wheelbase"       value="0.452"/>
  <xacro:property name="track_width"     value="0.490"/>

  <xacro:property name="base_z_offset" value="${wheel_radius}"/>

  <!-- ============================================================== -->
  <!-- Inertial macros                                                 -->
  <!-- ============================================================== -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m*(y*y + z*z)/12.0}" ixy="0.0" ixz="0.0"
        iyy="${m*(x*x + z*z)/12.0}" iyz="0.0"
        izz="${m*(x*x + y*y)/12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m*(3*r*r + h*h)/12.0}" ixy="0.0" ixz="0.0"
        iyy="${m*(3*r*r + h*h)/12.0}" iyz="0.0"
        izz="${m*r*r/2.0}"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================== -->
  <!-- Sensor modules                                                  -->
  <!-- ============================================================== -->
  <xacro:include filename="$(find scout_mini_description)/urdf/sensors/imu.xacro"/>
  <xacro:include filename="$(find scout_mini_description)/urdf/sensors/lidar_2d.xacro"/>

  <!-- ============================================================== -->
  <!-- Wheel macro                                                     -->
  <!-- ============================================================== -->
  <xacro:macro name="wheel" params="prefix wheel_name x_offset y_offset">
    <link name="${prefix}${wheel_name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_black_${prefix}${wheel_name}">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}${wheel_name}_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}${wheel_name}_wheel_link"/>
      <origin xyz="${x_offset} ${y_offset} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ============================================================== -->
  <!-- Main robot macro                                                -->
  <!-- ============================================================== -->
  <xacro:macro name="scout_mini_robot" params="prefix:=''
                                                use_imu:=true
                                                use_lidar:=true
                                                lidar_samples:=360
                                                imu_rate:=100">

    <!-- base_footprint -->
    <link name="${prefix}base_footprint"/>

    <!-- base_link -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
        <material name="scout_yellow_${prefix}">
          <color rgba="0.95 0.75 0.05 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
      </collision>
      <xacro:box_inertia m="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
    </link>

    <joint name="${prefix}base_footprint_to_base_link" type="fixed">
      <parent link="${prefix}base_footprint"/>
      <child link="${prefix}base_link"/>
      <origin xyz="0 0 ${base_z_offset}" rpy="0 0 0"/>
    </joint>

    <!-- Four wheels -->
    <xacro:wheel prefix="${prefix}" wheel_name="front_left"  x_offset="${ wheelbase/2}" y_offset="${ track_width/2}"/>
    <xacro:wheel prefix="${prefix}" wheel_name="front_right" x_offset="${ wheelbase/2}" y_offset="${-track_width/2}"/>
    <xacro:wheel prefix="${prefix}" wheel_name="rear_left"   x_offset="${-wheelbase/2}" y_offset="${ track_width/2}"/>
    <xacro:wheel prefix="${prefix}" wheel_name="rear_right"  x_offset="${-wheelbase/2}" y_offset="${-track_width/2}"/>

    <!-- Conditional sensors -->
    <xacro:if value="${use_imu}">
      <xacro:imu_sensor
        name="${prefix}imu"
        parent="${prefix}base_link"
        xyz="0 0 ${base_height + 0.01}"
        rpy="0 0 0"
        rate="${imu_rate}"
        topic="imu"/>
    </xacro:if>

    <xacro:if value="${use_lidar}">
      <xacro:lidar_2d_sensor
        name="${prefix}lidar"
        parent="${prefix}base_link"
        xyz="0.20 0 ${base_height + 0.03}"
        rpy="0 0 0"
        samples="${lidar_samples}"
        topic="scan"/>
    </xacro:if>

    <!-- Gazebo (per-instance: material + plugins) -->
    <xacro:scout_mini_gazebo prefix="${prefix}"/>

  </xacro:macro>

  <!-- ============================================================== -->
  <!-- Include the Gazebo macro definition                             -->
  <!-- ============================================================== -->
  <xacro:include filename="$(find scout_mini_description)/urdf/scout_mini.gazebo.xacro"/>

  <!-- ============================================================== -->
  <!-- Instantiate one robot with empty prefix (Scene 1 compatibility) -->
  <!-- This is overridden when launched via spawn_robot.launch.py      -->
  <!-- ============================================================== -->
  <xacro:scout_mini_robot prefix=""/>

</robot>
